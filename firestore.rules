rules_version = '2';

// JW Congregation Scheduler — Firestore security rules.
//
// Deployment: the self-hosting admin pastes this file into
// Firebase console -> Firestore Database -> Rules (see docs/SETUP-ADMIN.md).
//
// Model:
//  - One Firebase project = one congregation.
//  - publishers/{uid}.verified gates all congregation data.
//  - publishers/{uid}.roles.{section} grants per-section admin rights;
//    roles.fullAdmin grants everything.
//  - Sensitive personal data lives in publishers/{uid}/private/profile so that
//    ordinary verified publishers only see names/qualifications of others.
//  - First-admin bootstrap: congregation/meta can only ever be created once
//    (Firestore 'create' matches only when the doc does not exist); its
//    founderUid may then create a fully privileged publisher doc for itself.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function myPublisherPath() {
      return /databases/$(database)/documents/publishers/$(request.auth.uid);
    }

    function me() {
      return get(myPublisherPath()).data;
    }

    function isVerified() {
      return isSignedIn()
        && exists(myPublisherPath())
        && me().verified == true;
    }

    function hasRole(role) {
      return isVerified()
        && (me().roles[role] == true || me().roles.fullAdmin == true);
    }

    function metaPath() {
      return /databases/$(database)/documents/congregation/meta;
    }

    function isFounder() {
      return isSignedIn()
        && exists(metaPath())
        && get(metaPath()).data.founderUid == request.auth.uid;
    }

    // Roles map with every flag false (shape enforced on self-registration).
    function noRoles(roles) {
      return !roles.values().hasAny([true]);
    }

    // ---------- congregation ----------

    match /congregation/{docId} {
      // Signed-in but not-yet-verified users may read meta (congregation name
      // on the "awaiting verification" screen).
      allow read: if isSignedIn();
      // Bootstrap: 'create' only matches when the doc does not exist yet, so
      // whoever writes congregation/meta first becomes the founder. Racing
      // second writers hit the 'update' rule and are denied.
      allow create: if isSignedIn()
        && docId == 'meta'
        && request.resource.data.founderUid == request.auth.uid;
      allow update: if hasRole('fullAdmin');
      allow delete: if false;
    }

    // ---------- publishers ----------

    match /publishers/{publisherId} {
      // Own doc always readable (unverified users watch it for verification);
      // verified publishers read everyone (names/qualifications for schedules).
      allow read: if isSignedIn()
        && (request.auth.uid == publisherId || isVerified() || hasRole('publishers'));

      // Founder creates their own doc pre-verified with fullAdmin.
      // Anyone else self-registers strictly unverified with no roles.
      // Publisher-admins may create records for members without accounts.
      allow create: if hasRole('publishers')
        || (isSignedIn() && request.auth.uid == publisherId && isFounder()
            && request.resource.data.verified == true)
        || (isSignedIn() && request.auth.uid == publisherId
            && request.resource.data.verified == false
            && noRoles(request.resource.data.roles)
            && request.resource.data.get('appointment', 'none') == 'none');

      // Granting/removing rights ('roles') is restricted to full admins; a
      // limited publisher-admin may manage everyone else's fields but not their
      // rights. Self-service edits may not touch privilege fields at all.
      // 'moved' is an admin-only lifecycle flag (marking someone moved also
      // revokes their access), so members may not change it on their own
      // record. 'groupId' (ministry group membership) is likewise assigned by
      // admins only. 'appointment' (elder/MS) is denormalized here from the
      // private profile and admin-set only: members may keep it unchanged
      // (get() with a default tolerates legacy docs the client rewrites in
      // full) but not change it. status 'none' ("-" / not a publisher) is
      // admin-only in both directions; members may still freely switch among
      // the other status values.
      allow update: if (hasRole('publishers')
            && (hasRole('fullAdmin')
                || !request.resource.data.diff(resource.data).affectedKeys()
                    .hasAny(['roles'].toSet())))
        || (isSignedIn() && request.auth.uid == publisherId
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['verified', 'roles', 'qualifications', 'moved',
                    'groupId'].toSet())
            && request.resource.data.get('appointment', 'none')
                == resource.data.get('appointment', 'none')
            && (request.resource.data.status == resource.data.status
                || (request.resource.data.status != 'none'
                    && resource.data.status != 'none')));

      // Publisher-admins may remove anyone; a signed-in user may delete their
      // own record (self-service account deletion — Apple Guideline 5.1.1(v)).
      allow delete: if hasRole('publishers')
        || (isSignedIn() && request.auth.uid == publisherId);

      // Sensitive personal data: self + publisher-admins only.
      match /private/{docId} {
        allow read: if isSignedIn()
          && (request.auth.uid == publisherId || hasRole('publishers'));
        allow delete: if isSignedIn()
          && (request.auth.uid == publisherId || hasRole('publishers'));
        // Appointment (elder/MS) is set by publisher-admins only; a
        // self-created doc must leave it at the default.
        allow create: if hasRole('publishers')
          || (isSignedIn() && request.auth.uid == publisherId
              && request.resource.data.get('appointment', 'none') == 'none');
        // E-mail is the login identity; it may only change on records of
        // members without an app account (hasAccount != true).
        // Appointment may not change on self-edits; get() with a default
        // tolerates legacy docs that predate the field (the client always
        // writes the full document).
        allow update: if (isSignedIn()
            && (request.auth.uid == publisherId || hasRole('publishers')))
          && (!('email' in resource.data)
              || request.resource.data.email == resource.data.email
              || get(/databases/$(database)/documents/publishers/$(publisherId))
                  .data.hasAccount != true)
          && (hasRole('publishers')
              || request.resource.data.get('appointment', 'none')
                  == resource.data.get('appointment', 'none'));
      }
    }

    // ---------- information board ----------

    match /infoboard_items/{itemId} {
      allow read: if isVerified();
      allow write: if hasRole('infoBoard');
    }

    match /files/{fileId} {
      allow read: if isVerified();
      allow write: if hasRole('infoBoard');

      match /chunks/{chunkId} {
        allow read: if isVerified();
        allow write: if hasRole('infoBoard');
      }
    }

    // ---------- events ----------

    match /events/{eventId} {
      allow read: if isVerified();
      allow write: if hasRole('events');
    }

    // ---------- schedules ----------

    match /lmm_weeks/{weekId} {
      allow read: if isVerified();
      allow write: if hasRole('lmmSchedule');
    }

    match /weekend_weeks/{weekId} {
      allow read: if isVerified();
      allow write: if hasRole('weekendSchedule');
    }

    // Per-meeting schedule configuration (e.g. permanent custom assignments).
    // Doc id names the meeting type; each is writable by that schedule's role
    // so the same admins who edit the schedule manage its permanent slots.
    match /schedule_config/{docId} {
      allow read: if isVerified();
      allow write: if (docId == 'lmm' && hasRole('lmmSchedule'))
        || (docId == 'weekend' && hasRole('weekendSchedule'));
    }

    // Public talk title catalog (S-99); readable by all verified users
    // so the weekend talk picker can offer the titles.
    match /public_talks/{docId} {
      allow read: if isVerified();
      allow write: if hasRole('weekendSchedule');
    }

    match /pw_recurring/{ruleId} {
      allow read: if isVerified();
      allow write: if hasRole('publicWitnessing');
    }

    match /pw_slots/{slotId} {
      allow read: if isVerified();
      allow write: if hasRole('publicWitnessing');
    }

    match /pw_applications/{applicationId} {
      // A qualified publisher applies for a PW slot. Doc id {slotId}_{uid}
      // makes applying idempotent and works for not-yet-materialized
      // recurring slots (their virtual {ruleId}_{date} ids are stable).
      // Applicant names are admin-only: publishers must query with
      // publisherId == their own uid.
      allow read: if hasRole('publicWitnessing')
        || (isVerified() && resource.data.publisherId == request.auth.uid);
      allow create: if isVerified()
        && me().qualifications.publicWitnessing == true
        && request.resource.data.publisherId == request.auth.uid
        && applicationId == request.resource.data.slotId + '_' + request.auth.uid
        && request.resource.data.slotId is string
        && request.resource.data.slotId.size() > 0
        && request.resource.data.date is string
        && request.resource.data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && request.resource.data.keys()
            .hasOnly(['slotId', 'date', 'publisherId', 'appliedAt']);
      allow update: if false;
      allow delete: if hasRole('publicWitnessing')
        || (isVerified() && resource.data.publisherId == request.auth.uid);
    }

    match /fsm_recurring/{ruleId} {
      allow read: if isVerified();
      allow write: if hasRole('fieldServiceMeetings');
    }

    match /fsm_meetings/{meetingId} {
      allow read: if isVerified();
      allow write: if hasRole('fieldServiceMeetings');
    }

    // ---------- territories ----------

    match /territories/{territoryId} {
      allow read: if isVerified();
      allow write: if hasRole('territories');
    }

    match /territory_assignments/{assignmentId} {
      // Publishers see own assignments (client must query
      // where publisherId == uid); territory-admins see all.
      allow read: if hasRole('territories')
        || (isVerified() && resource.data.publisherId == request.auth.uid);
      allow create, delete: if hasRole('territories');
      // A publisher may only return their own territory (+ optional notes).
      allow update: if hasRole('territories')
        || (isVerified()
            && resource.data.publisherId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['returnedDate', 'returnNotes'].toSet()));
    }

    // ---------- ministry groups ----------
    // Membership lives on publishers/{uid}.groupId; the group doc stores
    // only the name and the designated overseer/assistant.

    match /ministry_groups/{groupId} {
      allow read: if isVerified();
      allow write: if hasRole('publishers');
    }

    // ---------- ministry reports ----------
    // reports/{yyyy-MM}/entries/{publisherId}

    match /reports/{month} {
      // Month parent docs are never written; entries live in the subcollection.
      allow read: if isVerified();
      allow write: if false;

      match /entries/{publisherId} {
        allow read: if hasRole('reports')
          || (isVerified() && request.auth.uid == publisherId);
        allow create, update: if hasRole('reports')
          || (isVerified() && request.auth.uid == publisherId);
        allow delete: if hasRole('reports');
      }
    }

    // ---------- meeting attendance ----------

    match /attendance/{entryId} {
      allow read: if hasRole('attendance') || hasRole('recordAttendance');
      allow write: if hasRole('attendance') || hasRole('recordAttendance');
    }
  }
}
